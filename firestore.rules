rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function myUser() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isAdmin() { return signedIn() && myUser().data.role == 'admin'; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /campaigns/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }
    match /smart_links/{id} {
      allow read: if signedIn() && (resource.data.publisherId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.publisherId == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.publisherId == request.auth.uid || isAdmin());
    }
    match /click_logs/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (signedIn() && resource.data.publisherId == request.auth.uid);
    }
    match /lead_submissions/{id} {
      allow create: if true;
      allow read: if isAdmin() || (signedIn() && resource.data.publisherId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /submissions/{id} {
      allow create: if true;
      allow read: if isAdmin() || (signedIn() && resource.data.publisherId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /withdrawals/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /withdraws/{id} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /transactions/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
    match /support_tickets/{id} {
      allow create: if signedIn();
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
